      "id": "node-meals",
      "name": "Meals",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [40, 0],
      "executeOnce": true
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Parse Claude's response and render HTML email\nconst ctx = $('Macros').first().json;\nconst llmResp = $json;\nlet meals = { pre: [], post: [] };\ntry {\n  const text = llmResp && llmResp.content && llmResp.content[0] && llmResp.content[0].text;\n  if (text) {\n    // Strip code fences if any slipped through\n    const cleaned = text.replace(/^```(?:json)?\\s*/i, '').replace(/```\\s*$/i, '').trim();\n    meals = JSON.parse(cleaned);\n  }\n} catch (e) {\n  meals = { pre: [], post: [], _error: String(e) };\n}\n\nconst w = ctx.workout;\nconst t = ctx.targets;\nconst wk = ctx.weekly;\nconst esc = s => String(s == null ? '' : s).replace(/[&<>\"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[c]));\n\nfunction mealCard(m) {\n  if (!m) return '';\n  const ingredients = (m.ingredients || []).map(i => `<li>${esc(i.quantity || '')} ${esc(i.item || i)}</li>`).join('');\n  const macros = m.macros || {};\n  return `\n    <div style=\"border:1px solid #e3e3e3;border-radius:8px;padding:14px;margin:8px 0;background:#fff;\">\n      <div style=\"font-weight:600;font-size:15px;margin-bottom:4px;\">${esc(m.name || 'Meal')}</div>\n      <div style=\"color:#666;font-size:12px;margin-bottom:8px;\">${esc(m.prep_minutes || '?')} min prep &middot; ${esc(macros.carbs_g || '?')}C / ${esc(macros.protein_g || '?')}P / ${esc(macros.fat_g || '?')}F &middot; ${esc(macros.calories || '?')} kcal</div>\n      <ul style=\"margin:6px 0 8px 18px;padding:0;font-size:13px;color:#333;\">${ingredients}</ul>\n      <div style=\"font-size:12px;color:#555;font-style:italic;\">${esc(m.rationale || '')}</div>\n    </div>`;\n}\n\nconst isRest = w.intensity === 'rest';\n\nconst preTargetRow = t.pre ? `\n  <tr><td style=\"padding:6px 10px;color:#666;\">Pre (${esc(t.pre.window)})</td>\n  <td style=\"padding:6px 10px;\">${esc(t.pre.carbsG)}g carbs &middot; ${esc(t.pre.proteinG)}g protein &middot; ${esc(t.pre.fatG)}</td></tr>` : '';\nconst duringTargetRow = t.during ? `\n  <tr><td style=\"padding:6px 10px;color:#666;\">During</td>\n  <td style=\"padding:6px 10px;\">${esc(t.during.carbsPerHour)} carbs/hr</td></tr>` : '';\nconst postTargetRow = t.post ? `\n  <tr><td style=\"padding:6px 10px;color:#666;\">Post (${esc(t.post.window)})</td>\n  <td style=\"padding:6px 10px;\">${esc(t.post.carbsG)}g carbs &middot; ${esc(t.post.proteinG)}g protein</td></tr>` : '';\nconst hydration = t.hydration ? `\n  <tr><td style=\"padding:6px 10px;color:#666;\">Hydration</td>\n  <td style=\"padding:6px 10px;\">${esc(t.hydration.mlDuring)} ml during &middot; ~${esc(t.hydration.sodiumMg)} mg sodium</td></tr>` : '';\n\nconst restBlock = isRest ? `\n  <p style=\"color:#444;\">No workout planned today. Recovery focus: protein-forward meals, hydration, mobility.</p>\n  <table style=\"border-collapse:collapse;font-size:13px;\">\n    <tr><td style=\"padding:6px 10px;color:#666;\">Daily target</td><td style=\"padding:6px 10px;\">${esc(t.daily.carbsG)}g C &middot; ${esc(t.daily.proteinG)}g P &middot; ${esc(t.daily.fatG)}g F</td></tr>\n  </table>` : '';\n\nconst weeklyLine = `${wk.workouts} workouts &middot; ${wk.totalMinutes} min &middot; TSS ${wk.totalTss} &middot; ${wk.totalKJ} kJ` +\n  (wk.avgSleepScore ? ` &middot; sleep ${wk.avgSleepScore}` : '') +\n  (wk.avgHrv ? ` &middot; HRV ${wk.avgHrv}` : '') +\n  (wk.avgReadiness ? ` &middot; readiness ${wk.avgReadiness}` : '');\n\nconst html = `<!doctype html><html><body style=\"font-family:-apple-system,Segoe UI,Helvetica,Arial,sans-serif;color:#222;background:#f6f7f9;padding:24px;\">\n<div style=\"max-width:680px;margin:0 auto;background:#fff;border-radius:12px;padding:24px;\">\n  <div style=\"font-size:12px;color:#888;letter-spacing:0.04em;text-transform:uppercase;\">${esc(ctx.today)}</div>\n  <h1 style=\"font-size:22px;margin:6px 0 2px;\">${esc(w.name)}</h1>\n  <div style=\"color:#555;font-size:14px;margin-bottom:14px;\">\n    ${esc(w.type)}${w.indoor ? ' (indoor)' : ''} &middot; ${esc(w.durationMin)} min &middot; TSS ${esc(w.tss)} &middot; ${esc(w.kJ)} kJ &middot; <strong style=\"text-transform:capitalize;\">${esc(w.intensity)}</strong> intensity\n  </div>\n  ${w.description ? `<details style=\"margin-bottom:14px;\"><summary style=\"cursor:pointer;color:#444;font-size:13px;\">Workout details</summary><pre style=\"white-space:pre-wrap;font-size:12px;color:#555;background:#fafafa;padding:10px;border-radius:6px;\">${esc(w.description)}</pre></details>` : ''}\n\n  <div style=\"background:#f0f4f8;border-radius:8px;padding:10px 14px;font-size:13px;color:#333;margin-bottom:18px;\">\n    <strong>Last 7 days:</strong> ${weeklyLine}\n  </div>\n\n  ${isRest ? restBlock : `\n  <h2 style=\"font-size:15px;margin:18px 0 6px;\">Macro targets</h2>\n  <table style=\"border-collapse:collapse;font-size:13px;width:100%;\">\n    ${preTargetRow}\n    ${duringTargetRow}\n    ${postTargetRow}\n    ${hydration}\n  </table>\n\n  <h2 style=\"font-size:15px;margin:22px 0 4px;\">Pre-workout options</h2>\n  ${(meals.pre || []).map(mealCard).join('') || '<div style=\"color:#999;font-size:13px;\">No options generated.</div>'}\n\n  <h2 style=\"font-size:15px;margin:22px 0 4px;\">Post-workout options</h2>\n  ${(meals.post || []).map(mealCard).join('') || '<div style=\"color:#999;font-size:13px;\">No options generated.</div>'}\n  `}\n\n  <div style=\"margin-top:24px;color:#999;font-size:11px;\">Generated by n8n &middot; intervals.icu + Claude</div>\n</div>\n</body></html>`;\n\nconst subject = isRest\n  ? `Rest day — recovery fuel (${ctx.today})`\n  : `Fuel: ${w.name} (${w.durationMin}m, TSS ${w.tss})`;\n\nreturn [{ json: { subject, html, to: ctx.profile.email, _meals: meals } }];"
      },
