    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Compute workout context + macro targets\nconst init = $('Init').first().json;\nconst profile = init.profile;\nconst bw = profile.bodyWeightKg;\n\n// HTTP Request returns body as $json (or as array of items if response is an array — handle both)\nfunction toArray(name) {\n  const items = $(name).all().map(i => i.json);\n  // If n8n already split a JSON-array response into items, items === the array\n  if (items.length === 1 && Array.isArray(items[0])) return items[0];\n  // Otherwise the array IS the multiple items\n  return items.filter(x => x && typeof x === 'object');\n}\n\nconst todayEvents = toArray('TodayEvents');\nconst weeklyEvents = toArray('WeeklyEvents');\nconst weeklyWellness = toArray('WeeklyWellness');\n\n// Pick today's primary workout (skip 'NOTE' category, prefer WORKOUT)\nconst todays = todayEvents.filter(e => e && e.category !== 'NOTE');\nconst workout = todays[0] || null;\n\nfunction restDay() {\n  return {\n    type: 'rest',\n    name: 'Rest day',\n    durationMin: 0,\n    tss: 0,\n    kJ: 0,\n    kcalBurned: 0,\n    intensity: 'rest',\n    description: '',\n    indoor: false\n  };\n}\n\nfunction summarizeWorkout(w) {\n  if (!w) return restDay();\n  const durationMin = Math.round((w.moving_time || 0) / 60);\n  const tss = Math.round(w.icu_training_load || 0);\n  const kJ = Math.round((w.joules || 0) / 1000);\n  const kcalBurned = kJ; // ~1 kcal per kJ of mechanical work for cycling\n  let intensity = 'easy';\n  if (tss >= 70 || durationMin >= 90) intensity = 'hard';\n  else if (tss >= 40 || durationMin >= 60) intensity = 'moderate';\n  return {\n    type: w.type || 'Workout',\n    name: w.name || 'Workout',\n    durationMin,\n    tss,\n    kJ,\n    kcalBurned,\n    intensity,\n    description: (w.description || '').slice(0, 500),\n    indoor: !!w.indoor,\n    startLocal: w.start_date_local || null\n  };\n}\n\nconst wo = summarizeWorkout(workout);\n\n// Macro targets\nfunction buildTargets(intensity, durationMin) {\n  if (intensity === 'rest') {\n    return {\n      pre: null,\n      during: null,\n      post: null,\n      daily: {\n        carbsG: Math.round(3 * bw),\n        proteinG: Math.round(1.8 * bw),\n        fatG: Math.round(1.0 * bw),\n        notes: 'Lower-carb, protein-forward day. Emphasize whole foods, hydration, electrolytes.'\n      }\n    };\n  }\n  const carbMultPre = intensity === 'hard' ? 1.5 : intensity === 'moderate' ? 1.0 : 0.6;\n  const pre = {\n    window: '2-3 hours before',\n    carbsG: Math.round(carbMultPre * bw),\n    proteinG: Math.round(0.3 * bw),\n    fatG: '<15g (keep low to ease digestion)',\n    fiberG: 'low (<5g)',\n    notes: 'Familiar foods only. Avoid new ingredients pre-session.'\n  };\n  const during = durationMin >= 90 ? {\n    carbsPerHour: intensity === 'hard' ? '60-90g' : '30-60g',\n    notes: 'Sip throughout. Mix glucose+fructose (e.g. 2:1) if >60g/hr to avoid GI distress.'\n  } : null;\n  const post = {\n    window: 'within 60 minutes',\n    carbsG: Math.round(1.0 * bw),\n    proteinG: Math.round(0.3 * bw),\n    fatG: 'moderate (fine to include)',\n    notes: 'Front-load protein within first hour. Hydrate with sodium.'\n  };\n  // Hydration estimate\n  const hydrationMl = Math.round(500 + (durationMin / 60) * 600);\n  const sodiumMg = intensity === 'hard' ? 800 : intensity === 'moderate' ? 500 : 300;\n  return { pre, during, post, hydration: { mlDuring: hydrationMl, sodiumMg, notes: 'Higher if hot/humid or you sweat heavily.' } };\n}\n\nconst targets = buildTargets(wo.intensity, wo.durationMin);\n\n// Weekly aggregates\nconst weeklyWorkouts = weeklyEvents.filter(e => e && e.category !== 'NOTE');\nconst weeklyTss = Math.round(weeklyWorkouts.reduce((s, w) => s + (w.icu_training_load || 0), 0));\nconst weeklyKJ = Math.round(weeklyWorkouts.reduce((s, w) => s + ((w.joules || 0) / 1000), 0));\nconst weeklyMinutes = Math.round(weeklyWorkouts.reduce((s, w) => s + ((w.moving_time || 0) / 60), 0));\n\nfunction avg(arr) { if (!arr.length) return null; return arr.reduce((s, n) => s + n, 0) / arr.length; }\nconst sleepScores = weeklyWellness.map(w => w && w.sleepScore).filter(n => typeof n === 'number');\nconst hrvValues = weeklyWellness.map(w => w && w.hrv).filter(n => typeof n === 'number');\nconst rhrValues = weeklyWellness.map(w => w && w.restingHR).filter(n => typeof n === 'number');\nconst readinessValues = weeklyWellness.map(w => w && w.readiness).filter(n => typeof n === 'number');\nconst latestWellness = weeklyWellness.length ? weeklyWellness[weeklyWellness.length - 1] : null;\n\nconst weekly = {\n  workouts: weeklyWorkouts.length,\n  totalTss: weeklyTss,\n  totalKJ: weeklyKJ,\n  totalMinutes: weeklyMinutes,\n  avgSleepScore: sleepScores.length ? Math.round(avg(sleepScores)) : null,\n  avgHrv: hrvValues.length ? Math.round(avg(hrvValues)) : null,\n  avgRestingHR: rhrValues.length ? Math.round(avg(rhrValues)) : null,\n  avgReadiness: readinessValues.length ? Math.round(avg(readinessValues)) : null,\n  todayWellness: latestWellness ? {\n    sleepScore: latestWellness.sleepScore || null,\n    hrv: latestWellness.hrv || null,\n    restingHR: latestWellness.restingHR || null,\n    readiness: latestWellness.readiness || null\n  } : null\n};\n\nreturn [{\n  json: {\n    profile,\n    today: init.today,\n    workout: wo,\n    targets,\n    weekly\n  }\n}];"
      },
