        "jsCode": "// ============================================================\n// EDIT THIS PROFILE — your stats, prefs, and email\n// ============================================================\nconst profile = {\n  email: 'steven@salesignition.com',\n  bodyWeightKg: 75,            // <-- update\n  sex: 'M',\n  preferences: ['high-protein', 'mediterranean'],\n  dislikes: [],                // e.g. ['cilantro']\n  vegetarian: false,\n  allergies: [],\n  cuisinePreference: 'flexible',\n  timezone: 'America/New_York'\n};\n\n// Compute today + last-7-day range in the configured timezone\nconst nowStr = new Date().toLocaleString('en-CA', { timeZone: profile.timezone, year:'numeric', month:'2-digit', day:'2-digit' });\nconst today = nowStr; // YYYY-MM-DD\nconst d = new Date(today + 'T00:00:00');\nconst start = new Date(d);\nstart.setDate(d.getDate() - 6);\nconst pad = n => String(n).padStart(2, '0');\nconst weekStart = `${start.getFullYear()}-${pad(start.getMonth()+1)}-${pad(start.getDate())}`;\n\nreturn [{ json: { profile, today, weekStart } }];"
